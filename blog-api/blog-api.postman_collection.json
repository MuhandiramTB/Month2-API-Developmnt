{
  "info": {
    "name": "Blog API",
    "description": "Complete Blog API collection with Auth, Users, Posts, and Comments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"Test User\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.data && jsonData.data.token) {",
                "  pm.collectionVariables.set('token', jsonData.data.token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.data && jsonData.data.token) {",
                "  pm.collectionVariables.set('token', jsonData.data.token);",
                "}",
                "pm.test('Status code is 200', function () {",
                "  pm.response.to.have.status(200);",
                "});",
                "pm.test('Has token', function () {",
                "  pm.expect(jsonData.data.token).to.be.a('string');",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/profile"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Updated Name\",\n  \"bio\": \"Updated bio text\"\n}"
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/1",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Get All Posts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts?page=1&limit=10&status=published",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "published" }
              ]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get All Posts (with search)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts?search=Node&tag=nodejs",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "search", "value": "Node" },
                { "key": "tag", "value": "nodejs" }
              ]
            },
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/1",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Post by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/slug/getting-started-with-nodejs",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Get Posts by User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/user/2",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My New Blog Post\",\n  \"content\": \"This is the full content of my new blog post. It covers important topics.\",\n  \"excerpt\": \"A brief summary of the post\",\n  \"status\": \"published\",\n  \"tags\": [\"javascript\", \"tutorial\"]\n}"
            }
          }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/posts/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Post Title\",\n  \"status\": \"published\"\n}"
            }
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/posts/1"
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Get Comments for Post",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts/1/comments",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts/1/comments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This is a great post! Thanks for sharing.\"\n}"
            }
          }
        },
        {
          "name": "Create Reply to Comment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/posts/1/comments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Thanks for your feedback!\",\n  \"parent_id\": 1\n}"
            }
          }
        },
        {
          "name": "Get Comment by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/comments/1",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/comments/1"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "auth": { "type": "noauth" }
          }
        }
      ]
    }
  ]
}
